{:paths ["src"]
 ;; langgraph-clj brings langchain-clj transitively (both zero-/single-dep,
 ;; all .cljc → portable to JVM / SCI / ClojureScript / GraalVM). Same runtime
 ;; robotaxi-actor / vehicle-design-actor / itonami ride on; a tailnet control
 ;; plane is just another sealed-intelligence ⊣ independent-governor StateGraph.
 :deps {io.github.com-junkawasaki/langgraph-clj
        {:local/root "../langgraph-clj"}}
 :aliases
 {;; offline workspace dev — pin transitive langchain-clj to local checkout
  :dev {:override-deps
        {io.github.com-junkawasaki/langchain-clj {:local/root "../langchain-clj"}}}
  ;; clojure -M:dev:run  → drive a tailnet through one CoordinationActor
  :run {:main-opts ["-m" "kekkai.sim"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main" "--lint" "src" "test" "--fail-level" "error"]}}}
